{
  "name": "quiz-biblico-pwa",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "db:local:setup": "node scripts/setup-local-preview.mjs",
    "dev:full": "pnpm run build && pnpm run db:local:setup && wrangler pages dev out --d1 DB=00000000-0000-4000-8000-000000000002 --compatibility-date 2026-07-15 --compatibility-flag nodejs_compat --persist-to .wrangler/local-state --ip 127.0.0.1 --port 8788",
    "dev:lan": "pnpm run build && pnpm run db:local:setup && node scripts/print-local-lan-addresses.mjs && wrangler pages dev out --d1 DB=00000000-0000-4000-8000-000000000002 --compatibility-date 2026-07-15 --compatibility-flag nodejs_compat --persist-to .wrangler/local-state --binding LOCAL_LAN_DEVELOPMENT=true --ip 0.0.0.0 --port 8788",
    "build": "next build",
    "build:pages-functions": "node scripts/prepare-pages-functions.mjs && wrangler pages functions build functions --outdir .pages-functions --project-directory . --build-output-directory out --output-routes-path out/_routes.json",
    "start": "next start",
    "test": "pnpm run test:all",
    "test:quick": "node --test tests/*.test.mjs",
    "test:unit": "node --test tests/competitive-integrity.test.mjs tests/runtime-integrity.test.mjs && node --experimental-loader ./tests/helpers/ts-loader.mjs --test tests/unit/quiz-core-adapter.test.mjs",
    "test:contracts": "node --test tests/security-contracts.test.mjs tests/pwa-accessibility.test.mjs tests/service-worker-behavior.test.mjs tests/architecture-alignment.test.mjs",
    "test:integration": "node --experimental-loader ./tests/helpers/ts-loader.mjs --test tests/integration/*.test.mjs",
    "test:e2e": "playwright test",
    "test:all": "pnpm run test:unit && pnpm run test:contracts && pnpm run test:integration",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .wrangler",
    "db:generate": "drizzle-kit generate",
    "worker:awards:types": "wrangler types workers/journey-awards/worker-configuration.d.ts --config workers/journey-awards/wrangler.jsonc",
    "worker:awards:types:check": "wrangler types workers/journey-awards/worker-configuration.d.ts --config workers/journey-awards/wrangler.jsonc --check",
    "worker:awards:check": "wrangler deploy --dry-run --config workers/journey-awards/wrangler.jsonc",
    "db:reconcile-migrations": "node scripts/reconcile-d1-migrations.mjs",
    "db:reconcile-migrations:apply": "node scripts/reconcile-d1-migrations.mjs --apply",
    "db:reconcile-migrations:verify-pending": "node scripts/reconcile-d1-migrations.mjs --verify-pending",
    "db:reconcile-migrations:verify-final": "node scripts/reconcile-d1-migrations.mjs --verify-final",
    "db:reconcile-migrations:snapshot": "node scripts/reconcile-d1-migrations.mjs --snapshot d1-before.json",
    "db:reconcile-migrations:compare": "node scripts/reconcile-d1-migrations.mjs --compare-snapshot d1-before.json",
    "db:reset-pilot:dry-run": "node scripts/reset-pilot-production-data.mjs --dry-run",
    "db:reset-pilot:apply": "node scripts/reset-pilot-production-data.mjs --apply",
    "db:reset-pilot:verify": "node scripts/reset-pilot-production-data.mjs --verify",
    "worker:awards:migrate": "wrangler d1 migrations apply quiz-biblico-db --remote --config workers/journey-awards/wrangler.jsonc",
    "worker:awards:deploy": "wrangler deploy --config workers/journey-awards/wrangler.jsonc"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-loading-skeleton": "3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "1.44.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.9.5",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.16",
    "wrangler": "4.110.0"
  },
  "type": "module"
}
