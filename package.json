{
  "name": "quiz-biblico-pwa",
  "version": "0.3.0-beta.1",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "pnpm run test:all",
    "test:quick": "node --test tests/*.test.mjs",
    "test:unit": "node --test tests/competitive-integrity.test.mjs tests/runtime-integrity.test.mjs",
    "test:contracts": "node --test tests/security-contracts.test.mjs tests/pwa-accessibility.test.mjs tests/service-worker-behavior.test.mjs",
    "test:integration": "node --experimental-loader ./tests/helpers/ts-loader.mjs --test tests/integration/*.test.mjs",
    "test:e2e": "playwright test",
    "test:all": "pnpm run test:unit && pnpm run test:contracts && pnpm run test:integration",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "worker:awards:types": "wrangler types workers/journey-awards/worker-configuration.d.ts --config workers/journey-awards/wrangler.jsonc",
    "worker:awards:types:check": "wrangler types workers/journey-awards/worker-configuration.d.ts --config workers/journey-awards/wrangler.jsonc --check",
    "worker:awards:check": "wrangler deploy --dry-run --config workers/journey-awards/wrangler.jsonc",
    "worker:awards:migrate": "wrangler d1 migrations apply quiz-biblico-db --remote --config workers/journey-awards/wrangler.jsonc",
    "worker:awards:deploy": "wrangler deploy --config workers/journey-awards/wrangler.jsonc"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-loading-skeleton": "3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.16",
    "wrangler": "4.110.0"
  },
  "type": "module"
}
